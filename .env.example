# Application Spring Boot — seule source de JWT_SECRET et secrets métier (ne pas les mettre dans .env racine).
# Voir README.md à la racine du dépôt pour la cartographie complète des fichiers .env.

# Database
DB_HOST=db
DB_PORT=3306
DB_NAME=esport_db
DB_USER=root
# Local : renseigner le mot de passe MySQL. Avec Docker Compose : surchargé par DB_ROOT_PASSWORD du .env racine.
DB_PASSWORD=

# JWT (obligatoire en prod ; changer JWT_SECRET invalide les tokens existants)
JWT_SECRET=
JWT_EXPIRATION_MS=3600000

# Compte admin initial (bootstrap)
ADMIN_PASSWORD=

# Spring AI / Ollama (réseau Docker)
OLLAMA_BASE_URL=http://ollama:11434