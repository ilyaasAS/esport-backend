# Application Spring Boot — secrets métier (JWT, admin) et connexion BDD hors conteneur.
# Voir README.md racine pour la cartographie complète des fichiers .env.

# Base de données (utilisateur applicatif dédié, jamais root).
# Sous docker compose : surchargé par DB_APP_USER / DB_APP_PASSWORD du .env racine.
DB_HOST=db
DB_PORT=3306
DB_NAME=esport_db
DB_USER=esport_app
DB_PASSWORD=changeme_app_password

# JWT (obligatoire ; >= 32 caractères ; changer JWT_SECRET invalide les tokens existants).
JWT_SECRET=changeme_jwt_secret_min_32_chars
JWT_EXPIRATION_MS=3600000

# Compte admin initial (bootstrap).
ADMIN_PASSWORD=changeme_admin_password

# Spring AI / Ollama (réseau Docker).
OLLAMA_BASE_URL=http://ollama:11434
